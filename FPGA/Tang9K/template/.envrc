# Tang Nano 1K project env
# 注意：.envrc 用的是 bash/sh 语法，不是 fish 语法

export OSS_CAD_SUITE=/opt/oss-cad-suite
export TANG1K_FAMILY=GW1NZ-1
export TANG1K_DEVICE='GW1NZ-LV1QN48C6/I5'

# OSS CAD Suite: yosys / nextpnr-himbaechel / gowin_pack
if [ -d "$OSS_CAD_SUITE/bin" ]; then
    PATH_add "$OSS_CAD_SUITE/bin"
fi

# Mason: verible-verilog-ls / lint / format
# 只在这个项目目录里临时加入 PATH，不污染全局 fish
if [ -d "$HOME/.local/share/nvim/mason/bin" ]; then
    PATH_add "$HOME/.local/share/nvim/mason/bin"
fi
